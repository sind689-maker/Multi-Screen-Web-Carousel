{
    "name": "multi-screen-web-carousel",
    "private": true,
    "version": "1.0.0",
    "description": "A cross-platform desktop application for multi-screen photo carousels, featuring highly customizable, fullscreen slideshows.",
    "author": "yuanyq <yyq.cloud@qq.com> (https://github.com/sind689-maker)",
    "keywords": [
        "electron",
        "react",
        "carousel",
        "multi-screen",
        "digital-signage"
    ],
    "license": "MIT",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "electron:dev": "concurrently -n vite,electron -c cyan,yellow \"vite\" \"wait-on tcp:localhost:5173 && electron .\"",
        "electron:build": "npm run build && electron-builder",
        "electron:pack": "npm run build && electron-builder --dir",
        "electron:build:win": "npm run build && electron-builder --win",
        "electron:build:mac": "npm run build && electron-builder --mac"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.2",
        "swiper": "^12.1.4",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "electron": "30",
        "electron-builder": "^26.8.1",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "vite": "^8.0.10",
        "wait-on": "^9.0.5"
    },
    "build": {
        "appId": "com.makesomething.multi-screen-carousel",
        "productName": "Multi Screen Carousel",
        "icon": "build/icon",
        "asar": true,
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "category": "public.app-category.photography"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true
        }
    }
}